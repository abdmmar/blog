---
import ResponsiveImage from "./ResponsiveImage.astro";

type ImageItem = {
  src: string;
  alt?: string;
  caption?: string;
};

type Props = {
  images: ImageItem[];
  layout?: "full" | "content";
  columns?: 2 | 3 | 4;
};

const { images, layout = "content", columns = 2 } = Astro.props;

const gridClass = {
  2: "grid-cols-2 sm:grid-cols-1",
  3: "grid-cols-3 sm:grid-cols-1 md:grid-cols-2",
  4: "grid-cols-4 sm:grid-cols-2 md:grid-cols-2",
}[columns];

const sizesMap = {
  2: "(max-width: 640px) 100vw, 50vw",
  3: "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw",
  4: "(max-width: 640px) 50vw, (max-width: 1024px) 50vw, 25vw",
};
---

<div class:list={[layout === "full" ? "fullwidth-breakout" : "max-w-[70ch]"]}>
  <div class={`grid ${gridClass} gap-2`}>
    {
      images.map((img) => (
        <figure
          data-lightbox-src={img.src}
          data-lightbox-alt={img.alt || undefined}
          data-lightbox-caption={img.caption || undefined}
        >
          <ResponsiveImage
            src={img.src}
            alt={img.alt || ""}
            sizes={layout === "full" ? "100vw" : sizesMap[columns]}
            class="w-full h-full max-h-screen object-cover"
          />
          {img.caption && (
            <figcaption class="text-xs text-gray-500 dark:text-gray-400 mt-2 italic">
              {img.caption}
            </figcaption>
          )}
        </figure>
      ))
    }
  </div>
</div>
