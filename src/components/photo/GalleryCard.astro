---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"photoGallery">;
  index: number;
};

const { entry, index } = Astro.props;
const { data } = entry;
const delay = index * 75;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a
  href={`/photo/${data.slug}`}
  class="photo-card block group"
  style={{ animationDelay: `${delay}ms` }}
>
  {
    data.type === "single" && (
      <div class="flex flex-col gap-2">
        <div class="overflow-hidden">
          <img
            src={data.coverImage}
            alt={data.alt || data.title}
            loading="lazy"
            decoding="async"
            class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-105"
          />
        </div>
        <div class="flex flex-row flex-wrap justify-between gap-1 items-center">
          <strong class="font-semibold text-sm text-gray-900 dark:text-gray-100">
            {data.title}
          </strong>
          <span class="text-xs text-gray-500 dark:text-gray-400">
            {dateFormatter.format(data.date)}
          </span>
        </div>
      </div>
    )
  }

  {
    data.type === "album" && (
      <div class="flex flex-col gap-2">
        <div class="overflow-hidden">
          <div class="grid grid-cols-2 gap-1">
            <img
              src={data.coverImage}
              alt={data.title}
              loading="lazy"
              decoding="async"
              class="col-span-2 w-full h-48 sm:h-32 object-cover transition-transform duration-300 group-hover:scale-105"
            />
            {data.images.slice(1, 3).map((img) => (
              <img
                src={img.src}
                alt={img.alt || ""}
                loading="lazy"
                decoding="async"
                class="w-full h-20 sm:h-14 object-cover"
              />
            ))}
          </div>
        </div>
        <div class="flex flex-row flex-wrap justify-between gap-1 items-center">
          <strong class="font-semibold text-sm text-gray-900 dark:text-gray-100">
            {data.title}
          </strong>
          <span class="text-xs text-gray-500 dark:text-gray-400">
            {data.images.length} Photos
          </span>
        </div>
      </div>
    )
  }

  {
    data.type === "journal" && (
      <div class="col-span-2 sm:col-span-1">
        <div class="grid grid-cols-2 sm:grid-cols-1 gap-4 bg-gray-950 dark:bg-gray-900 overflow-hidden">
          <img
            src={data.coverImage}
            alt={data.title}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          />
          <div class="flex flex-col justify-between gap-2 py-4 pr-4 sm:px-4 sm:pb-4 text-white">
            <div class="flex flex-col gap-2">
              <strong class="font-semibold">{data.title}</strong>
              <p class="line-clamp-3 text-xs text-gray-300">{data.description}</p>
            </div>
            <span class="text-xs text-gray-400">
              {dateFormatter.format(data.date)}
            </span>
          </div>
        </div>
      </div>
    )
  }
</a>

<style>
  .photo-card {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.3s ease-out forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
