---
import Footer from "@/components/Footer.astro";
import { ArrowLeft, ArrowRight } from "@/components/icons";
import FootnotesSidebar from "@/components/photo/FootnotesSidebar.tsx";
import ResponsiveImage from "@/components/photo/ResponsiveImage.astro";
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";

type GalleryEntry = CollectionEntry<"photoGallery">;

type Props = {
  entry: GalleryEntry;
  headings?: MarkdownHeading[];
  nextEntry?: GalleryEntry;
  previousEntry?: GalleryEntry;
};

const { entry, headings, nextEntry, previousEntry } = Astro.props;
const { data } = entry;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const title = data.title;
const description = data.type === "journal" ? data.description : "";
const coverImage = data.coverImage;
const date = data.date;
const author = data.type === "journal" ? data.author : undefined;
const keywords = data.type === "journal" ? data.keywords : undefined;
const slug = data.slug;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  image: coverImage,
  datePublished: date.toISOString(),
  author: author
    ? { "@type": "Person", name: author }
    : undefined,
  publisher: {
    "@type": "Person",
    name: "Abdullah Ammar",
    url: "https://abdmmar.com",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `https://abdmmar.com/photo/${slug}`,
  },
  ...(keywords ? { keywords: keywords.join(", ") } : {}),
});
---

<BaseLayout meta={{ title, description, image: coverImage, ogType: "article" }}>
  <!-- SEO: JSON-LD structured data -->
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  {keywords && (
    <meta name="keywords" content={keywords.join(", ")} slot="head" />
  )}
  <meta property="article:published_time" content={date.toISOString()} slot="head" />
  {author && <meta property="article:author" content={author} slot="head" />}

  <!-- Fixed top nav -->
  <nav class="journal-nav fixed top-0 left-0 right-0 z-40 px-8 py-3 flex items-center sm:px-4">
    <a
      href="/photo"
      class="flex items-center gap-2 text-white/80 hover:text-white transition-colors text-sm"
    >
      <ArrowLeft class="h-4 w-4" />
      <span>Photo</span>
    </a>
    <span class="nav-title text-sm font-medium opacity-0 transition-opacity duration-300 ml-0.5 truncate">
      <span class="opacity-40 mx-1.5">|</span>
      <span>{title}</span>
    </span>
  </nav>

  <!-- Hero: full-viewport cover image with title overlay -->
  <header class="journal-hero relative w-screen h-screen -mt-10 -mx-10 sm:-mt-5 sm:-mx-5">
    <ResponsiveImage
      src={coverImage}
      alt={title}
      loading="eager"
      sizes="100vw"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
    <div class="absolute bottom-0 left-0 right-0 pb-16 sm:pb-10">
      <div class="journal-content">
        <span class="text-amber-400 text-sm font-medium tracking-wider uppercase mb-3 block">
          Photo Journal
        </span>
        <h1 class="text-5xl font-bold text-white leading-tight mb-4 sm:text-3xl">
          {title}
        </h1>
        <div class="flex items-center gap-4 text-white/70 text-sm">
          {author && <span>{author}</span>}
          {author && <span class="text-white/40">&middot;</span>}
          <time datetime={date.toISOString()}>
            {dateFormatter.format(date)}
          </time>
        </div>
      </div>
    </div>
  </header>

  <!-- Content area -->
  <article class="journal-article mt-16 sm:mt-10">
    {description && (
      <p class="journal-body text-gray-600 dark:text-gray-400 text-xl leading-relaxed mb-12 sm:text-lg">
        {description}
      </p>
    )}

    <div id="journal-content" class="journal-content">
      <slot />
    </div>
  </article>

  <!-- Mobile footnotes -->
  <div class="journal-body mt-16 sm:block hidden">
    <FootnotesSidebar client:load mobile />
  </div>

  <!-- Prev/Next navigation -->
  <nav class="journal-body flex flex-col gap-4 mb-16">
    {
      previousEntry && (
        <a
          href={`/photo/${previousEntry.data.slug}`}
          class="py-4 px-5 flex items-center text-gray-600 group dark:text-gray-200 justify-between text-sm border border-gray-200 dark:border-gray-800 rounded-sm hover:bg-gray-50 bg-white dark:bg-gray-950 dark:hover:bg-gray-900 transition-all"
        >
          <ArrowLeft class="h-5 w-5 min-w-[20px] mr-5 group-hover:text-gray-600 transition-all text-gray-300 dark:text-gray-600 dark:group-hover:text-gray-300" />
          <span>{previousEntry.data.title}</span>
        </a>
      )
    }
    {
      nextEntry && (
        <a
          href={`/photo/${nextEntry.data.slug}`}
          class="py-4 px-5 flex items-center text-gray-600 group dark:text-gray-200 justify-between text-sm border border-gray-200 dark:border-gray-800 rounded-sm hover:bg-gray-50 bg-white dark:bg-gray-950 dark:hover:bg-gray-900 transition-all"
        >
          <span>{nextEntry.data.title}</span>
          <ArrowRight class="h-5 w-5 min-w-[20px] ml-5 group-hover:text-gray-600 transition-all text-gray-300 dark:text-gray-600 dark:group-hover:text-gray-300" />
        </a>
      )
    }
  </nav>

  <Footer />
</BaseLayout>

<style>
  /* Centered body text column */
  .journal-body {
    max-width: 70ch;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  /* Content column — wider to accommodate margin notes */
  .journal-content {
    max-width: calc(70ch + 260px);
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    position: relative;
  }

  /* Nav styling: transparent over hero, glass over content */
  .journal-nav {
    transition: background-color 0.3s ease;
    -webkit-backdrop-filter: blur(0px);
    backdrop-filter: blur(0px);
  }

  .journal-nav.scrolled {
    background-color: rgba(255, 255, 255, 0.65);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .journal-nav.scrolled :global(a),
  .journal-nav.scrolled .nav-title {
    color: rgb(55, 65, 81);
  }

  .journal-nav.scrolled .nav-title {
    opacity: 1;
  }

  :global(.dark) .journal-nav.scrolled {
    background-color: rgba(3, 7, 18, 0.65);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  :global(.dark) .journal-nav.scrolled :global(a),
  :global(.dark) .journal-nav.scrolled .nav-title {
    color: rgb(209, 213, 219);
  }

  /* Body text styling */
  .journal-content :global(> p) {
    max-width: 70ch;
    margin-bottom: 1.5em;
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  .journal-content :global(h2) {
    max-width: 70ch;
    font-size: 1.625rem;
    font-weight: 600;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
  }

  .journal-content :global(h3) {
    max-width: 70ch;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  /* Sidenotes — positioned in right margin on desktop, aligned with reference text */
  .journal-content :global(.sidenote) {
    float: right;
    clear: right;
    width: 200px;
    margin-right: -230px;
    margin-top: 0.125rem;
    margin-bottom: 1.25rem;
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgb(107, 114, 128);
    position: relative;
  }

  :global(.dark) .journal-content :global(.sidenote) {
    color: rgb(156, 163, 175);
  }

  /* Content images: max viewport height */
  .journal-content :global(figure img) {
    max-height: 100vh;
  }

  /* Spacing between content elements */
  .journal-content :global(figure) {
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .journal-content :global(figure figcaption) {
    margin-top: 0.75rem;
  }

  /* Full-width breakout for images/galleries */
  .journal-content :global(.fullwidth-breakout) {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    overflow: hidden;
    margin-top: 3rem;
    margin-bottom: 3rem;
  }

  /* Stacked parallax breakout — image sticks while content scrolls over.
     Uses margin instead of transform to avoid breaking position:sticky. */
  .journal-content :global(.parallax-breakout) {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-top: 0;
    margin-bottom: 0;
    z-index: 0;
  }

  /* Content sections between parallax images — solid background scrolls over sticky images */
  .journal-content :global(.parallax-content-section) {
    position: relative;
    z-index: 1;
    background-color: white;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  :global(.dark) .journal-content :global(.parallax-content-section) {
    background-color: rgb(3, 7, 18);
  }

  /* On tablet and below: hide sidenotes inline, show at bottom */
  @media (max-width: 1279px) {
    .journal-content {
      max-width: 70ch;
    }

    .journal-content :global(.sidenote) {
      display: none;
    }
  }
</style>

<script>
  // Nav background on scroll
  function initNav() {
    const nav = document.querySelector(".journal-nav");
    if (!nav) return;

    const onScroll = () => {
      if (window.scrollY > window.innerHeight * 0.8) {
        nav.classList.add("scrolled");
      } else {
        nav.classList.remove("scrolled");
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // Wrap content between parallax images into sections with solid backgrounds
  // so they visually scroll over the sticky parallax images
  function initParallaxSections() {
    const content = document.getElementById("journal-content");
    if (!content) return;

    const children = Array.from(content.children);
    const hasParallax = children.some((c) =>
      c.classList.contains("parallax-breakout"),
    );
    if (!hasParallax) return;

    let wrapper: HTMLDivElement | null = null;

    children.forEach((child) => {
      if (child.classList.contains("parallax-breakout")) {
        // End current wrapper, leave parallax as a direct child
        wrapper = null;
        return;
      }

      if (!wrapper) {
        wrapper = document.createElement("div");
        wrapper.className = "parallax-content-section";
        child.parentNode!.insertBefore(wrapper, child);
      }
      wrapper.appendChild(child);
    });
  }

  initNav();
  initParallaxSections();
  document.addEventListener("astro:after-swap", () => {
    initNav();
    initParallaxSections();
    const event = new CustomEvent("reset-footnotes");
    window.dispatchEvent(event);
  });
</script>
