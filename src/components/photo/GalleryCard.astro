---
import type { CollectionEntry } from "astro:content";
import GalleryCardSingle from "./GalleryCardSingle.astro";
import GalleryCardAlbum from "./GalleryCardAlbum.astro";
import GalleryCardJournal from "./GalleryCardJournal.astro";

type Props = {
  entry: CollectionEntry<"photoGallery">;
  index: number;
};

const { entry, index } = Astro.props;
const { data } = entry;
const delay = index * 75;
---

<a
  href={`/photo/${data.slug}`}
  class="photo-card block group"
  style={{ animationDelay: `${delay}ms` }}
>
  {data.type === "single" && <GalleryCardSingle entry={entry as any} />}
  {data.type === "album" && <GalleryCardAlbum entry={entry as any} />}
  {data.type === "journal" && <GalleryCardJournal entry={entry as any} />}
</a>

<style>
  .photo-card {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.3s ease-out forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
