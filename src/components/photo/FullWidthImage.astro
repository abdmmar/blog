---
type Props = {
  src: string;
  alt: string;
  caption?: string;
};

const { src, alt, caption } = Astro.props;
---

<figure class="fullwidth-breakout">
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="w-full max-h-screen object-cover"
  />
  {caption && (
    <figcaption class="max-w-[70ch] mx-auto text-sm text-gray-500 dark:text-gray-400 mt-3 px-5 italic">
      {caption}
    </figcaption>
  )}
</figure>
